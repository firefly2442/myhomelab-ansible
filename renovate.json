{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": ["config:recommended"],

  "regexManagers": [
    {
      "fileMatch": [".*\\.ya?ml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+(?:url|src):\\s*.*?v?(?<currentValue>\\d+(?:\\.\\d+)*(?:\\+k3s\\d+)?)"
      ]
    },
    {
      "fileMatch": [".*\\.ya?ml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+INSTALL_K3S_VERSION=v(?<currentValue>[^\\s]+)"
      ]
    }
  ]
}